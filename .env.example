# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase anon/public key — used for user-scoped auth calls
SUPABASE_ANON_KEY=

# Supabase service role key — used as fallback for admin-level edge function calls
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of this deployment (used to build the /login link shown to users)
BASE_URL=https://almostreal-production.up.railway.app

# HTTP port — set automatically by Railway. When unset, stdio transport is used (Claude Desktop).
PORT=
