# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase anon/public key
SUPABASE_ANON_KEY=

# User access token — obtained from Supabase Auth after signing in.
# The MCP server forwards this as the Authorization header to edge functions.
# Required for credit deduction and user-scoped storage.
SUPABASE_ACCESS_TOKEN=

# HTTP port for Railway / cloud deployment.
# When set, the server listens on SSE at /sse and /messages.
# When unset (local dev), the server uses stdio transport for Claude Desktop.
PORT=
